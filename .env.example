# ─────────────────────────────────────────────────────────────
# Supabase — Project Settings → API
# ─────────────────────────────────────────────────────────────
# Your project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# The "anon" / public key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# Gemini (Google AI Studio) — used ONLY server-side by the Weekly
# Review API route. Never prefix this with NEXT_PUBLIC_ (that would
# leak it to the browser). Free key at https://aistudio.google.com/apikey
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────
# App URL — used to build the OAuth redirect.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Web Push — daily reminder notifications.
# Generate a keypair with:  npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# A random secret so only Vercel Cron can hit the reminders endpoint.
# Generate with:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=

# Supabase service-role key (server-only) — lets the reminder cron read all push
# subscriptions, bypassing RLS. Supabase → Project Settings → API → service_role.
# NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
